# Šablona produkčních proměnných — zkopírujte na server jako:
#   /var/www/west-county-akce/.env.production
# Nikdy necommitujte skutečné hodnoty do gitu.

# Veřejná URL aplikace (bez koncového lomítka) — OAuth, e-maily, QR, odkazy
NEXT_PUBLIC_APP_URL=https://app.westcounty.cz

# Supabase (projekt v Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Pouze server — admin operace, service role (nikdy do klienta)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — odesílání e-mailů (dotazník, faktury, schválení)
RESEND_API_KEY=re_xxxxxxxx
# Volitelné — ověřená doména v Resend
RESEND_FROM_EMAIL=WEST COUNTY <noreply@westcounty.cz>

# Cron / ruční volání POST /api/reminders/run (Bearer token)
REMINDER_ENGINE_SECRET=generate-long-random-secret

# Volitelné — token pro render faktur (fallback: SERVICE_ROLE nebo RESEND klíč)
INVOICE_RENDER_SECRET=

# Next.js / Node (obvykle nastaví PM2 ecosystem)
NODE_ENV=production
PORT=3000
